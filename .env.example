# ============================================================
# NightVibe Clubs – Variables de entorno (PLANTILLA)
# ------------------------------------------------------------
# Copia este archivo a .env.local (desarrollo) y configura las
# mismas variables en Vercel (Project Settings -> Environment Variables).
#
# IMPORTANTE: Solo se incluyen variables NEXT_PUBLIC_* porque este
# proyecto es 100% frontend. NUNCA pongas claves SECRETAS de Stripe,
# SendGrid, MongoDB, JWT, etc. en variables NEXT_PUBLIC_* : todo lo
# que empieza por NEXT_PUBLIC_ se incrusta en el bundle del navegador
# y es PÚBLICO. Esos secretos viven solo en el backend.
# ============================================================

# URL base de la API de NightVibe (backend).
# El código usa indistintamente estas dos variables segun el modulo,
# por lo que conviene definir AMBAS con el mismo valor hasta unificarlas.
NEXT_PUBLIC_API_BASE=https://api.nightvibe.life
NEXT_PUBLIC_BACKEND_URL=https://api.nightvibe.life

# Firebase (solo claves PÚBLICAS de cliente). Opcionales: solo se
# necesitan si se reactiva la autenticación con Firebase.
NEXT_PUBLIC_FB_API_KEY=
NEXT_PUBLIC_FB_AUTH_DOMAIN=
NEXT_PUBLIC_FB_PROJECT_ID=
NEXT_PUBLIC_FB_APP_ID=
